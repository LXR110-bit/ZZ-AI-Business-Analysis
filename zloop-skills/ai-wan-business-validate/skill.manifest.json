  "verification": {
    "smoke_prompt": "说明如何校验 active_process_manifest、active_analysis_manifest、evidence_pack、insights.json、known_gap、LLM 白名单、effective_history_weeks、过度归因和核心机型遗漏，并输出 validation_report/final_status；不要跑 SQL、不要自动发布。",
