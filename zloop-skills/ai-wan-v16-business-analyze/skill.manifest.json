{
  "version": "1",
  "skill_kind": "analysis",
  "skill_md": "SKILL.md",
  "runtime": {
    "target": "remote_sandbox"
  },
  "dependencies": {
    "skills": [],
    "runtime": [
      "zloop_runtime"
    ]
  },
  "verification": {
    "smoke_prompt": "说明 AI小万经营分析 v1.6.5 如何只读 APIHub server_context，把 processed_data 先生成 evidence_pack，再按飞书五层法和双模型复核输出 findings 与 dashboard display_insights；不得写服务器。",
    "side_effect_policy": "read_only",
    "user_scenarios": [
      "AI 小万 v1.6 多阶段 Loop 自动执行到 analyze 阶段。",
      "手动检查某个 analyze 阶段输出是否具备 evidence_pack、findings、display_contract、display_insights、review_notes 和 analysis_trace。",
      "effective_history_weeks 不足 8 周时降级为 wow_only。"
    ]
  },
  "llm_policy": {
    "uses_llm": true,
    "allowed_llms": [
      "GLM-5.2",
      "DeepSeek V4 Pro"
    ],
    "fallback_to_other_llm": false,
    "daily": {
      "primary_writer": "GLM-5.2",
      "reviewer": "DeepSeek V4 Pro"
    },
    "deep_dive": {
      "primary_analyst": "DeepSeek V4 Pro",
      "formatter": "GLM-5.2"
    }
  },
  "zloop": {
    "generated_by": "codex",
    "candidate_schema_version": "1"
  },
  "contracts": {
    "stage": "analyze",
    "contract_version": "ai-wan-v1.6.5-analyze",
    "analysis_core_contract_version": "ai-wan-analysis-core/v1.6.5",
    "analysis_method": "ai-wan-five-layer-analysis/v1",
    "server_usage": "read_only",
    "input": "processed_data",
    "output_type": "analysis_result",
    "min_history_weeks_for_trend": 8,
    "history_insufficient_policy": "downgrade_to_wow_only",
    "evidence_policy": {
      "generate_evidence_pack_first": true,
      "require_evidence_id": true,
      "do_not_send_full_raw_data_to_llm": true,
      "known_gap_not_causal": true
    },
    "api_bridge": {
      "read": "POST /api/aiwan/read",
      "runtime_client": "zloop_runtime.hub",
      "read_runtime_path": "/v2/aiwan/api/aiwan/read",
      "write_allowed": false
    },
    "outputs": [
      "analysis_result.evidence_pack",
      "analysis_result.insights",
      "analysis_result.summary",
      "analysis_result.display_contract",
      "analysis_result.display_insights",
      "analysis_result.findings",
      "analysis_result.review_notes",
      "analysis_result.analysis_trace"
    ],
    "display_contract": "dashboard-business-overview-insights-map/v1",
    "server_bridge_publish_source": "analysis_result.display_insights"
  }
}
