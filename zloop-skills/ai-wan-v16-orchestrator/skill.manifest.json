{
  "version": "1",
  "skill_kind": "tool",
  "skill_md": "SKILL.md",
  "runtime": {
    "target": "remote_sandbox"
  },
  "dependencies": {
    "skills": [
      {
        "name": "xinghe-data-explore",
        "kind": "exact"
      }
    ],
    "runtime": [
      "zloop_runtime"
    ]
  },
  "verification": {
    "smoke_prompt": "说明 AI小万主编排 v1.6.15 如何先运行 scripts/aiwan_inline_state_machine.py，真实执行 read(xinghe runtime SQL+单次 materialize 响应+快速 URL 下载 Excel/CSV 转换+raw_cache；履约空 CSV 降级 known_gaps/warn)→process(Node 以 --max-old-space-size=${AIWAN_PROCESS_NODE_OLD_SPACE_MB:-8192} 处理大 CSV+品类映射+process pipeline)→analyze(APIHub read 上下文+display_insights)→validate(display 校验+APIHub write 且 output_type=validation_result)；物化失败时必须输出 debug/materialize 响应并 failed，不能被 Bash 600 秒后台化吞掉。",
    "side_effect_policy": "allow_write_with_confirmation",
    "user_scenarios": [
      "AI 小万 v1.6 多阶段 Loop 自动执行。",
      "手动单独重跑或检查某个阶段。"
    ]
  },
  "zloop": {
    "generated_by": "codex",
    "candidate_schema_version": "1"
  },
  "contracts": {
    "stage": "orchestrator",
    "contract_version": "ai-wan-v1.6.15-stage",
    "stage_order": [
      "read",
      "process",
      "analyze",
      "validate"
    ],
    "server_usage": {
      "read": "none",
      "process": "none",
      "analyze": "read_only",
      "validate": "final_write"
    },
    "api_bridge": {
      "read": "POST /api/aiwan/read",
      "write": "POST /api/aiwan/write",
      "runtime_client": "zloop_runtime.hub",
      "read_runtime_path": "/v2/aiwan/api/aiwan/read",
      "write_runtime_path": "/v2/aiwan/api/aiwan/write"
    },
    "required_stage_outputs": {
      "read": ["read_result", "raw_cache", "sql_status"],
      "process": ["processed_data", "category_mapping_manifest"],
      "analyze": ["analysis_result.findings", "analysis_result.display_insights"],
      "validate": ["validation_result", "server_write_confirmed"]
    }
  }
}
