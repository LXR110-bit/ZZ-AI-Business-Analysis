{
  "msg_type": "interactive",
  "card": {
    "config": {"wide_screen_mode": true},
    "header": {
      "title": {"tag": "plain_text", "content": "{{title}}"},
      "template": "{{template_color}}"
    },
    "elements": [
      {
        "tag": "div",
        "text": {"tag": "lark_md", "content": "{{body}}"}
      },
      {"tag": "hr"},
      {
        "tag": "action",
        "actions": [
          {
            "tag": "button",
            "text": {"tag": "plain_text", "content": "{{button_text}}"},
            "type": "primary",
            "url": "{{link_url}}"
          }
        ]
      }
    ]
  }
}
