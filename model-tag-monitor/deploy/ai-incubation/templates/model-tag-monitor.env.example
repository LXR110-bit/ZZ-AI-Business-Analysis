# Copy to /opt/soft/model-tag-monitor/conf/model-tag-monitor.env on the AI incubation host.
# Fill values on the server only. Do NOT commit the filled file.

NODE_ENV=production
TZ=Asia/Shanghai

# Local Express API kept on loopback; Nginx exposes port 80.
PORT=8848
API_BASE=http://127.0.0.1:8848

MONITOR_DIR=/opt/soft/model-tag-monitor/app/model-tag-monitor
DATA_DIR=/opt/data/model-tag-monitor/current
IMPORT_DIR=/opt/data/model-tag-monitor/raw/imports
LOG_DIR=/opt/log/model-tag-monitor/worker
DASHBOARD_PUBLIC_DIR=/opt/data/model-tag-monitor/current
DASHBOARD_URL=http://<NEW_HOST_INTRANET_IP>/

KEEP_WEEKS=10
TARGET_WEEKS=
FEISHU_DRY_RUN=1

# Required secrets. Set real values only on the server.
ACCESS_CODE=
ACCESS_TOKEN_SECRET=
FEISHU_CHAT_ID=
FEISHU_OPEN_ID=
OPENAI_API_KEY=
OPENAI_BASE_URL=
