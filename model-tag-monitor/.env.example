# 端口，默认 8848
PORT=8848

# 代理上游：设置后 /api/* 会透传到该地址，/api/dashboard 在本地基于上游数据组装
# 常用值：线上现役服务
# PROXY_UPSTREAM=http://47.84.94.234:8848

# CSV 数据目录（数据流水线投递路径），默认为项目内 data/imports/
# IMPORT_DIR=/root/workspace/ZZ-AI-Business-Analysis-base-migration/data/imports

# Dashboard/monitor 周窗口；生产当前默认覆盖 W19-W28（10周）
# TARGET_WEEKS=2026-W19,2026-W20,2026-W21,2026-W22,2026-W23,2026-W24,2026-W25,2026-W26,2026-W27,2026-W28
# KEEP_WEEKS=10
